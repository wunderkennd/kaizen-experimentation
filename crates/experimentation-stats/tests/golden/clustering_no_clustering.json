{
  "test_name": "clustering_no_clustering",
  "r_command": "# 1 session per user → no within-cluster correlation.\n# Design effect should be approximately 1.0.\n# sandwich::vcovCL(lm(y ~ treatment), cluster = ~user_id, type = 'HC1')",
  "observations": [
    {"value": 1.0, "cluster_id": "u1", "is_treatment": false},
    {"value": 2.0, "cluster_id": "u2", "is_treatment": false},
    {"value": 3.0, "cluster_id": "u3", "is_treatment": false},
    {"value": 4.0, "cluster_id": "u4", "is_treatment": false},
    {"value": 5.0, "cluster_id": "u5", "is_treatment": false},
    {"value": 6.0, "cluster_id": "u6", "is_treatment": true},
    {"value": 7.0, "cluster_id": "u7", "is_treatment": true},
    {"value": 8.0, "cluster_id": "u8", "is_treatment": true},
    {"value": 9.0, "cluster_id": "u9", "is_treatment": true},
    {"value": 10.0, "cluster_id": "u10", "is_treatment": true}
  ],
  "alpha": 0.05,
  "expected": {
    "design_effect_near_1": true,
    "naive_se_close_to_clustered_se": true
  },
  "tolerance": 1e-6
}
