    {"value": 1.99, "cluster_id": "u1", "is_treatment": false},
    {"value": 2.00, "cluster_id": "u1", "is_treatment": false},
    {"value": 8.00, "cluster_id": "u2", "is_treatment": false},
    {"value": 8.01, "cluster_id": "u2", "is_treatment": false},
    {"value": 7.99, "cluster_id": "u2", "is_treatment": false},
    {"value": 8.02, "cluster_id": "u2", "is_treatment": false},
    {"value": 8.00, "cluster_id": "u2", "is_treatment": false},
    {"value": 3.00, "cluster_id": "u3", "is_treatment": true},
    {"value": 3.01, "cluster_id": "u3", "is_treatment": true},
