    {"outcome": 2.5, "is_treatment": false, "assignment_probability": 0.55},
    {"outcome": 8.0, "is_treatment": true, "assignment_probability": 0.3},
    {"outcome": 7.0, "is_treatment": true, "assignment_probability": 0.4},
    {"outcome": 9.0, "is_treatment": true, "assignment_probability": 0.35},
