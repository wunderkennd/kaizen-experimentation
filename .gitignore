# ============================================
# Agent runtime state — see CLAUDE.md "Files That Must NOT Be Tracked in Git"
# ============================================

# .Jules/ — Jules session state (task IDs, scratch buffers, etc.)
.Jules/

# ============================================
# Claude Code & Multiclaude
# ============================================

# .claude/ — commit project settings and agent definitions,
# ignore user-local overrides and runtime state

# Commit these (do NOT gitignore):
#   .claude/settings.json          — project-level settings (Agent Teams flag, permissions)
#   .claude/agents/pr-triage.md    — the repo's own subagent definitions (allowlisted below)

# Third-party agent library (The Agency) is NOT committed — restore on demand
# via `just install-agents`. Repo-authored agents are allowlisted individually.
.claude/agents/*
!.claude/agents/pr-triage.md

# Ignore user-local and runtime:
.claude/settings.local.json
.claude/worktrees/
.claude/teams/
.claude/tasks/
.claude/credentials/
.claude/statsig/
.claude/cache/
.claude/*.log

# Project-scoped skills are restored from skills-lock.json (do NOT commit content):
#   skills-lock.json               — committed (source of truth)
#   .agents/skills/                — regenerated by `just install-skills`
#   .claude/skills/, .devin/skills/, .junie/skills/  — harness symlinks regenerated by `just install-skills`
.agents/
.claude/skills/
.devin/skills/
.junie/skills/

# .multiclaude/ — commit agent definitions and repo config,
# ignore runtime state and daemon artifacts

# Commit these (do NOT gitignore):
#   .multiclaude/agents/           — persistent agent definitions (the 7 Kaizen agents)
#   .multiclaude/config.json       — repo-level Multiclaude configuration

# Ignore runtime state:
.multiclaude/state/
.multiclaude/messages/
.multiclaude/locks/
.multiclaude/*.pid
.multiclaude/*.log
.multiclaude/worktrees/
tsconfig.tsbuildinfo

# Legacy status files (replaced by GitHub Issues)
docs/coordination/status/*
!docs/coordination/status/README.md

# ============================================
# Beads (Gas Town ↔ GitHub Issues projection)
# ============================================
# `bd init` writes its own .beads/.gitignore that excludes the Dolt DB,
# runtime locks, and logs. The portable export .beads/issues.jsonl is NOT
# ignored there — commit it intentionally via `just beads-export` so teammates
# can `bd import` after `git pull`.

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# ============================================
# Graphify (knowledge-graph snapshots)
# ============================================
# Commit these (do NOT gitignore):
#   graphify-out/graph.json        — the graph (committed as a versioned snapshot)
#   graphify-out/GRAPH_REPORT.md   — audit report
#   graphify-out/graph.html        — interactive viz
#   graphify-out/manifest.json     — file snapshot for `graphify --update`
#   graphify-out/cost.json         — cumulative token tracker
#   graphify-out/memory/*.md       — saved Q&A traces

# Ignore intermediates, recomputable cache, and query-time scratch:
graphify-out/.graphify_*
graphify-out/.vocab.txt
graphify-out/cache/

# Go module build binaries (nested Pulumi programs)
infra/github-governance/github-governance
__pycache__/
