# ==============================================================================
# Experimentation Platform — Environment Configuration
# ==============================================================================
# Copy to .env and adjust values for your environment.
#   cp .env.example .env
#
# Docker Compose and the Makefile automatically load .env when present.
# ==============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=experimentation
POSTGRES_USER=experimentation
POSTGRES_PASSWORD=localdev
DATABASE_URL=postgresql://experimentation:localdev@localhost:5432/experimentation?sslmode=disable

# --- Kafka --------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Internal Docker network address (used by services running inside Docker)
KAFKA_BOOTSTRAP_SERVERS_INTERNAL=kafka:29092
SCHEMA_REGISTRY_URL=http://localhost:8081

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Service Ports (gRPC / ConnectRPC) ---------------------------------------
# Rust services
ASSIGNMENT_SERVICE_PORT=50051
PIPELINE_SERVICE_PORT=50052
ANALYSIS_SERVICE_PORT=50053
POLICY_SERVICE_PORT=50054
# Go services
MANAGEMENT_SERVICE_PORT=50055
METRICS_SERVICE_PORT=50056
FLAGS_SERVICE_PORT=50057
ORCHESTRATION_SERVICE_PORT=50058
# UI
UI_PORT=3000
API_URL=http://localhost:50055

# --- Observability ------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
# Set to "pretty" for human-readable local dev logs
# LOG_FORMAT=pretty

# OpenTelemetry (when monitoring stack is running)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=experimentation
JAEGER_UI_URL=http://localhost:16686
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# --- Feature Flags (internal) ------------------------------------------------
# Enable debug endpoints on services (health, pprof, metrics)
ENABLE_DEBUG_ENDPOINTS=true
# Enable assignment dry-run mode (returns assignment but doesn't log exposure)
ASSIGNMENT_DRY_RUN=false

# --- Delta Lake / Spark (production only) -------------------------------------
# DELTA_LAKE_PATH=s3://experimentation-data/delta
# SPARK_MASTER=spark://spark-master:7077

# --- RBAC / Auth (production only) --------------------------------------------
# AUTH_PROVIDER=oidc
# AUTH_ISSUER_URL=https://auth.example.com
# AUTH_CLIENT_ID=experimentation-platform
# AUTH_AUDIENCE=experimentation-api
