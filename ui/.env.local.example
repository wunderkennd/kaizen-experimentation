# UI Environment — copy to .env.local
# When NEXT_PUBLIC_MOCK_API=true, all API calls are intercepted by MSW (no backend needed).
# Set to false (or remove) to use real backends via Next.js proxy rewrites.
NEXT_PUBLIC_MOCK_API=true

# Backend service URLs (used by Next.js rewrites in next.config.js)
# Only needed when NEXT_PUBLIC_MOCK_API=false
BACKEND_MANAGEMENT_URL=http://localhost:50055
BACKEND_METRICS_URL=http://localhost:50056
BACKEND_ANALYSIS_URL=http://localhost:50053
BACKEND_BANDIT_URL=http://localhost:50054

# Auth (dev defaults — set via AuthProvider or headers)
NEXT_PUBLIC_USER_EMAIL=alice@streamco.com
NEXT_PUBLIC_USER_ROLE=experimenter
